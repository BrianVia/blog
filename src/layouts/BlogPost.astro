---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface AdjacentPost {
  slug: string;
  title: string;
}

export interface Props {
  content: {
    title: string;
    description: string;
    pubDate: string;
    modifiedDate?: string;
    slug: string;
    tags?: string[];
    heroImageUrl?: string;
    heroImageAlt?: string;
  };
  prevPost?: AdjacentPost;
  nextPost?: AdjacentPost;
}

const {
  content: { title, description, pubDate, modifiedDate, slug, tags = [], heroImageUrl, heroImageAlt },
  prevPost,
  nextPost,
} = Astro.props as Props;

const prevUrl = prevPost ? `https://brianvia.blog/posts/${prevPost.slug}` : undefined;
const nextUrl = nextPost ? `https://brianvia.blog/posts/${nextPost.slug}` : undefined;

// Use heroImageUrl directly
const heroImageSrc = heroImageUrl;
const heroImageAltText = heroImageAlt || title;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const blogPosting = {
  headline: title,
  description,
  image: heroImageSrc,
  datePublished: new Date(pubDate).toISOString(),
  dateModified: modifiedDate ? new Date(modifiedDate).toISOString() : undefined,
  keywords: tags,
};

const breadcrumbs = [
  { name: "Journal", item: "https://brianvia.blog" },
  { name: title },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <BaseHead
      title={title}
      description={description}
      imageUrl={heroImageSrc}
      imageAlt={heroImageAltText}
      canonicalRoute={`posts/${slug}`}
      type="article"
      pubDate={pubDate}
      modifiedDate={modifiedDate}
      tags={tags}
      blogPosting={blogPosting}
      breadcrumbs={breadcrumbs}
      prevUrl={prevUrl}
      nextUrl={nextUrl}
    />
  </head>

  <body>
    <Header />

    <article class="wrapper py-16 md:py-24">
      <!-- Header -->
      <header class="text-center max-w-3xl mx-auto mb-16 md:mb-24">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-3 justify-center mb-6">
            {tags.map(tag => (
              <a href={`/tags/${encodeURIComponent(tag)}`} class="text-xs font-sans font-bold tracking-widest uppercase text-accent hover:text-accent-hover transition-colors">
                {tag}
              </a>
            ))}
          </div>
        )}
        
        <h1 class="text-5xl md:text-6xl font-bold font-heading text-ink mb-6 leading-[1.1]">
          {title}
        </h1>
        
        <div class="flex items-center justify-center gap-3 text-ink-light font-sans text-sm uppercase tracking-widest">
          <time>{formattedDate}</time>
        </div>

        {heroImageSrc && (
          <div class="mt-12 relative shadow-editorial rounded-sm overflow-hidden aspect-[16/9] bg-ink/5">
            <img
              src={heroImageSrc}
              alt={heroImageAltText}
              class="w-full h-full object-cover"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </div>
        )}
      </header>

      <!-- Content -->
      <main id="main-content" class="post-content mx-auto">
        <slot />
      </main>

      <!-- Post Navigation -->
      <footer class="max-w-3xl mx-auto mt-24 pt-12 border-t border-ink/5 space-y-12">
        {(prevPost || nextPost) && (
          <nav aria-label="Post navigation" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {prevPost ? (
              <a
                href={`/posts/${prevPost.slug}`}
                rel="prev"
                class="group block p-6 border border-ink/10 rounded-sm hover:border-accent transition-colors"
              >
                <span class="text-xs font-sans font-bold uppercase tracking-widest text-ink-lighter block mb-2">
                  ← Previous
                </span>
                <span class="font-heading font-bold text-lg text-ink group-hover:text-accent transition-colors">
                  {prevPost.title}
                </span>
              </a>
            ) : <div />}
            {nextPost ? (
              <a
                href={`/posts/${nextPost.slug}`}
                rel="next"
                class="group block p-6 border border-ink/10 rounded-sm hover:border-accent transition-colors md:text-right"
              >
                <span class="text-xs font-sans font-bold uppercase tracking-widest text-ink-lighter block mb-2">
                  Next →
                </span>
                <span class="font-heading font-bold text-lg text-ink group-hover:text-accent transition-colors">
                  {nextPost.title}
                </span>
              </a>
            ) : <div />}
          </nav>
        )}

        <a
          href="/"
          class="inline-flex items-center gap-3 text-ink font-sans font-bold uppercase tracking-widest text-xs hover:text-accent transition-colors group"
        >
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Journal
        </a>
      </footer>
    </article>

    <Footer />
  </body>
</html>
