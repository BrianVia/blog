---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  return allPosts
    .filter((post) => post.data.published === true)
    .map((post) => ({
      params: { slug: post.data.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Transform data to match the expected BlogPost layout props
const content = {
  title: post.data.title,
  description: post.data.description || '',
  pubDate: post.data.createdAt?.toISOString() || post.data.pubDate.toISOString(),
  heroImageUrl: post.data.heroImageUrl,
  heroImageAlt: post.data.heroImageAlt,
  slug: post.data.slug,
  tags: post.data.tags || []
};
---

<BlogPost content={content}>
  <Content />
</BlogPost>
